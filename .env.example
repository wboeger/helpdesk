# Postgres connection. Railway provides this automatically when you add a Postgres plugin.
# For local dev, point to your own Postgres:
DATABASE_URL=postgresql://user:pass@localhost:5432/helpdesk

# Admin login for write/ingest endpoints (HTTP Basic).
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# Optional: enables AI extraction of Q&A from pasted WhatsApp exports.
# Without it, ingest returns the parsed messages for manual entry.
ANTHROPIC_API_KEY=

# Optional: comma-separated origins allowed to embed the widget.
# Use your homepage origin(s), e.g. https://mysite.com. Default: * (any).
ALLOWED_ORIGINS=*
